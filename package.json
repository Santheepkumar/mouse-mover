{
  "name": "robotjs",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "cli": "node index.js",
    "dist": "electron-builder",
    "dist:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "robotjs": "^0.6.0"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.antigravity.mousejiggler",
    "productName": "Mouse Mover Pro",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "mover-child.js"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "mover-child.js",
      "iconTemplate.png",
      "iconTemplate@2x.png",
      "icon.png",
      "package.json",
      "node_modules/**/*"
    ]
  }
}

